# V-Legal Bot Environment Configuration

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
APP_NAME=V-Legal Bot
APP_VERSION=1.0.0
DEBUG=true

# Vector Database
CHROMA_PERSIST_DIR=F:\PhapLuatAI\vectordb
CHROMA_COLLECTION_NAME=legal_documents

# Document Processing
DATA_DIR=F:\PhapLuatAI\Data
CHUNK_SIZE=3000
CHUNK_OVERLAP=200

# LLM Settings
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Retrieval Settings
RETRIEVAL_TOP_K=10

# Server
HOST=0.0.0.0
PORT=8000
